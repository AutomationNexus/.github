{
  "name": "protect-main",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": ["refs/heads/main"],
      "exclude": []
    }
  },
  "rules": [
    {"type": "deletion"},
    {"type": "non_fast_forward"},
    {"type": "pull_request"},
    {"type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": false,
        "required_status_checks": [
          {"context": "ci / Guard Main Source Branch"},
          {"context": "ci / hygiene"},
          {"context": "ci / lint"},
          {"context": "ci / test-standards"},
          {"context": "ci / test"},
          {"context": "semgrep / Semgrep"}
        ]
      }
    }
  ]
}
