{
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git push origin dev:*)",
      "Bash(git push origin main:*)"
    ]
  }
}
