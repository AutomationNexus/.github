{
  "$schema": "https://opencode.ai/config.json",
  "shell": "powershell",
  "model": "openai/gpt-5.5",
  "small_model": "anthropic/claude-haiku-4-5",
  "default_agent": "plan",
  "agent": {
    "plan": {
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "instructions": [
        ".opencode/plan-instructions.md"
      ]
    },
    "build": {
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "instructions": [
        ".opencode/build-instructions.md"
      ]
    },
    "general": { "disable": true },
    "explore": { "disable": true },
    "scout": { "disable": true }
  },
  "share": "disabled",
  "snapshot": true,
  "watcher": {
    "ignore": [
      ".git/**",
      ".venv/**",
      "**/__pycache__/**",
      ".ruff_cache/**",
      ".pytest_cache/**"
    ]
  },
  "instructions": [
    ".opencode/project-rules.md"
  ],
  "permission": {
    "read": {
      "*": "allow",
      ".env": "deny",
      ".env.*": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      ".env.example": "allow",
      "**/.env.example": "allow",
      "secrets.yaml": "deny",
      "**/secrets.yaml": "deny",
      "secrets.yaml.example": "allow",
      "**/secrets.yaml.example": "allow",
      "**/.credentials.json": "deny",
      "AGENT-HANDOFF.md": "deny",
      "AGENTS.md": "deny",
      "CLAUDE.md": "deny"
    },
    "edit": {
      "*": "allow",
      ".env": "deny",
      ".env.*": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      ".env.example": "allow",
      "**/.env.example": "allow",
      "secrets.yaml": "deny",
      "**/secrets.yaml": "deny",
      "secrets.yaml.example": "allow",
      "**/secrets.yaml.example": "allow",
      "**/.credentials.json": "deny",
      "AGENT-HANDOFF.md": "deny",
      "AGENTS.md": "deny",
      "CLAUDE.md": "deny"
    },
    "bash": {
      "*": "allow",
      "git reset --hard*": "deny",
      "git clean*": "deny",
      "Get-Content .env*": "deny",
      "type .env*": "deny",
      "cat .env*": "deny",
      "Get-Content secrets.yaml*": "deny",
      "type secrets.yaml*": "deny",
      "cat secrets.yaml*": "deny",
      "Get-Content **/.credentials.json*": "deny",
      "type **/.credentials.json*": "deny",
      "cat **/.credentials.json*": "deny"
    }
  }
}
