# Local test/build artifacts from verifying templates/<group>/ bundles before committing.
# (Runtime .gitignore for repos *created from* the templates lives in
# templates/_shared/gitignore -- this file is only for this repo's own working tree.)
.venvtest/
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
*.egg-info/
.coverage
dist/
build/

# Local backups created by scripts/sync-workspace.sh before overwriting the
# non-versioned workspace-root CLAUDE.md/.claude copies.
workspace/.backups/
